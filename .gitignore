# Secrets — never commit these
.env
token.txt

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Logs — track directory but not log files
logs/*
!logs/.gitkeep

# OS
.DS_Store
Thumbs.db

# Backtest candle cache
data_cache/

# AI runtime-written files (Claude overwrites these; do not track)
config/overlay.yaml

# A1 volume profiles (runtime data)
data_cache/profiles/

# Web app auth token (single-user, never commit)
config/webapp_token.txt
webapp/static/
